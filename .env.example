# observable-agent example environment.  Copy to .env and adjust for your setup.
# Every value has a sensible default in config.py; for a localhost SigNoz + Ollama
# setup you usually only need the first few.

# --- LLM: provider-neutral, any OpenAI-compatible endpoint --------------------
# Local-first by default (Ollama at :11434): the whole loop runs offline, free,
# and with no telemetry leaving the box. Point GENAI_BASE_URL at vLLM, OpenAI,
# Together, Groq, etc. to run the identical code against a hosted model.
GENAI_BASE_URL=http://localhost:11434/v1
GENAI_API_KEY=ollama                  # Ollama ignores the value; any string works
GENAI_SYSTEM=ollama                   # the gen_ai.system span attribute
AGENT_MODEL=llama3.2:3b               # qwen2.5:3b is more reliable for tool-calling
AGENT_MAX_OUTPUT_TOKENS=300
# (OLLAMA_BASE_URL / OLLAMA_API_KEY are still honoured as back-compat aliases.)

# --- Optional cloud escalation tier (opt-in; leave unset to stay fully offline) -
# The healer decides with the LOCAL model by default. If a fix does not hold on
# verify AND all three vars below are set, it escalates that decision to this
# stronger hosted model. Unset = escalation disabled = no off-box calls, ever.
# GENAI_ESCALATION_MODEL=gpt-4o-mini
# GENAI_ESCALATION_BASE_URL=https://api.openai.com/v1
# GENAI_ESCALATION_API_KEY=sk-...
# GENAI_ESCALATION_SYSTEM=openai

# --- OpenTelemetry / SigNoz ingest --------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # SigNoz OTLP/HTTP
OTEL_SERVICE_NAME=observable-agent
DEPLOY_ENV=dev

# --- SigNoz MCP server (the agent reads its OWN telemetry back) ----------------
# Foundry installs this alongside SigNoz. Point at its streamable-HTTP endpoint.
# Required by the self-healing loop (self_heal.py) and self-debug (self_debug.py).
SIGNOZ_MCP_URL=http://localhost:8000/mcp
# Hard per-call ceiling (seconds) for those MCP reads, so a server that accepts the
# socket but never answers surfaces as an error the fail-closed sensors turn into
# UNKNOWN instead of freezing the heal loop.
# MCP_TIMEOUT_S=20

# --- Advanced / normally auto-managed -----------------------------------------
# The self-healing orchestrator sets these per-subprocess to inject a fault and
# arm the fix, so you rarely set them by hand. Documented so runs are reproducible.
# EXPERIMENT_ID=                       # tags spans+metrics to compare cohorts
# CHAOS_DROP_RESPONSE_ONCE=0           # 1 = drop+retry the first response (retry tax)
# LLM_MAX_ATTEMPTS=1
# COST_BUDGET_USD=0                    # >0 arms the per-request cost kill-switch
# CHAOS_RUNAWAY=0                      # 1 = simulate a runaway, token-burning loop
# CHAOS_RUNAWAY_CALLS=12

# --- Economics: the plug-and-play money model ---------------------------------
# All money numbers (token prices, cost of downtime, cost SLO, spend budget) live
# in economics.yaml so you can plug in YOUR figures without touching code. These
# env vars override that file for a quick per-run change; leave unset to use it.
# ECONOMICS_CONFIG=economics.yaml         # path to your economics file
# ECON_ACTIVE_DOWNTIME_PROFILE=gartner_baseline   # itic_enterprise_2024 | itic_regulated_2024 | custom
# ECON_REQUESTS_PER_DAY=100000            # your production volume (turns a per-request saving into a monthly bill)
# ECON_BILLING_MODEL=gpt-4o-mini          # which hosted price to project spend against
# ECON_COST_MAX_CALLS_PER_REQ=6           # cost SLO: over this many llm.chat/request is a runaway-spend breach
# ECON_NOMINAL_CALL_COST_USD=0.00004      # fallback per-call cost for the spend headline
# ECON_PER_REQUEST_BUDGET_USD=0.0001      # budget the cost circuit breaker arms
