# observable-agent — example environment.  Copy to .env and adjust for your setup.
# Every value has a sensible default in config.py; for a localhost SigNoz + Ollama
# setup you usually only need the first few.

# --- LLM (any OpenAI-compatible endpoint; Ollama exposes one at :11434/v1) ------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama                 # Ollama ignores the value; any string works
AGENT_MODEL=llama3.2:3b               # qwen2.5:3b is more reliable for tool-calling
AGENT_MAX_OUTPUT_TOKENS=300

# --- OpenTelemetry / SigNoz ingest --------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # SigNoz OTLP/HTTP
OTEL_SERVICE_NAME=observable-agent
DEPLOY_ENV=dev

# --- SigNoz MCP server (the agent reads its OWN telemetry back) ----------------
# Foundry installs this alongside SigNoz. Point at its streamable-HTTP endpoint.
# Required by the self-healing loop (self_heal.py) and self-debug (self_debug.py).
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# --- Advanced / normally auto-managed -----------------------------------------
# The self-healing orchestrator sets these per-subprocess to inject a fault and
# arm the fix, so you rarely set them by hand. Documented so runs are reproducible.
# EXPERIMENT_ID=                       # tags spans+metrics to compare cohorts
# CHAOS_DROP_RESPONSE_ONCE=0           # 1 = drop+retry the first response (retry tax)
# LLM_MAX_ATTEMPTS=1
# COST_BUDGET_USD=0                    # >0 arms the per-request cost kill-switch
# CHAOS_RUNAWAY=0                      # 1 = simulate a runaway, token-burning loop
# CHAOS_RUNAWAY_CALLS=12
